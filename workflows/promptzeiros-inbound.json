                "operation": "contains"
              }
            },
            {
              "id": "opt-parar",
              "leftValue": "={{ $json.user_message }}",
              "rightValue": "PARAR",
              "operator": {
                "type": "string",
                "operation": "contains"
              }
            },
            {
              "id": "opt-cancelar",
              "leftValue": "={{ $json.user_message }}",
              "rightValue": "CANCELAR",
              "operator": {
                "type": "string",
                "operation": "contains"
              }
            }
          ]
        },
        "options": {}
      },
      "id": "bcd6b61d-3623-4d3f-9c8a-70c4cd018915",
