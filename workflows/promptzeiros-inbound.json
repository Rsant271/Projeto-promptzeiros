      "id": "62428a03-6aa6-4778-9913-2210f0df4ca5",
      "name": "Simple Memory (Demo)",
      "type": "@n8n/n8n-nodes-langchain.memoryBufferWindow",
      "typeVersion": 1.3,
      "position": [
        1072,
        480
      ]
