    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const aiOutput = $input.item.json.output || $input.item.json.text || '';\nconst markerRegex = /TRIAGEM_COMPLETA\\{[^}]*\\}/;\nconst match = aiOutput.match(markerRegex);\n\nif (match) {\n  const cleanMessage = aiOutput.replace(markerRegex, '').trim();\n  let triagemData = {};\n  try {\n    const jsonStr = match[0].replace('TRIAGEM_COMPLETA', '');\n    triagemData = JSON.parse(jsonStr);\n  } catch (e) {\n    triagemData = { parse_error: e.message };\n  }\n  return {\n    output: cleanMessage,\n    triagem_complete: true,\n    triagem_data: triagemData,\n    raw_ai_output: aiOutput\n  };\n}\n\nreturn {\n  output: aiOutput,\n  triagem_complete: false,\n  raw_ai_output: aiOutput\n};"
      },
